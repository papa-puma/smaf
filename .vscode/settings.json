{
  "files.eol": "\n",
  "files.encoding": "utf8",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "[quarto]": {
    "editor.wordWrap": "on"
  },
  "yaml.schemas": {
    "https://json.schemastore.org/quarto.json": "_quarto.yml"
  },
  "cSpell.words": [
    "Andre",
    "Guettler",
    "Modigliani",
    "Quarto",
    "revealjs",
    "smaf",
    "Padmaperuma",
    "scrartcl",
    "tinytex",
    "Ulm"
  ]
}
